{
  "name": "collector-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:report": "playwright show-report",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:rgaa": "cypress run --spec cypress/e2e/rgaa-pack.cy.ts",
    "test:rgaa:auto": "node ./scripts/run-cypress-rgaa.mjs",
    "lighthouse:prepare": "node -e \"const fs=require('fs');fs.rmSync('.lighthouseci/chrome-profile',{recursive:true,force:true});fs.mkdirSync('.lighthouseci/tmp',{recursive:true});fs.mkdirSync('.lighthouseci/chrome-profile',{recursive:true});\"",
    "lighthouse": "node ./scripts/run-lhci.mjs",
    "lighthouse:open": "start lighthouse-reports"
  },
